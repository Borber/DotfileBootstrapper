+    function luaString(value) {
+        return JSON.stringify(`${value ?? ""}`);
+    }
+
+    function windowSelector(address) {
+        const raw = `${address ?? ""}`.trim();
+        if (raw.length === 0)
+            return "";
+        return raw.startsWith("address:") ? raw : `address:${raw}`;
+    }
+
+    function luaWorkspaceValue(workspace) {
+        const numeric = Number(workspace);
+        if (Number.isFinite(numeric))
+            return `${numeric}`;
+        return luaString(workspace);
+    }
+
+    function dispatchWorkspace(workspaceId) {
+        if (Hyprland.usingLua)
+            Hyprland.dispatch(`hl.dsp.focus({ workspace = ${luaWorkspaceValue(workspaceId)} })`);
+        else
+            Hyprland.dispatch(`workspace ${workspaceId}`);
+    }
+
+    function dispatchSpecialWorkspace(name) {
+        const workspace = `special:${name}`;
+        if (Hyprland.usingLua)
+            Hyprland.dispatch(`hl.dsp.focus({ workspace = ${luaString(workspace)} })`);
+        else
+            Hyprland.dispatch(`togglespecialworkspace ${name}`);
+    }
+
+    function dispatchMoveWindowToWorkspace(workspace, address) {
+        const selector = windowSelector(address);
+        if (!selector)
+            return;
+        if (Hyprland.usingLua)
+            Hyprland.dispatch(`hl.dsp.window.move({ workspace = ${luaWorkspaceValue(workspace)}, window = ${luaString(selector)} })`);
+        else
+            Hyprland.dispatch(`movetoworkspacesilent ${workspace},${selector}`);
+    }
+
+    function dispatchFocusWindow(address) {
