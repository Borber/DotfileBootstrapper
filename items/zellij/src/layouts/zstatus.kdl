layout {
    pane

    pane size=1 borderless=true {
        plugin location="zjstatus" {
            format_left  "{mode}"
            format_right "{tabs}"
            format_space "#[bg=#272e33]"

            mode_locked  "#[fg=#272e33,bg=#e67e80,bold] ● "
            mode_normal  "#[fg=#272e33,bg=#dbbc7f,bold] ○ #[fg=#272e33,bg=#a7c080,bold] n #[fg=#859289,bg=#2e383c] pane #[fg=#272e33,bg=#83c092,bold] c #[fg=#859289,bg=#2e383c] tab #[fg=#272e33,bg=#7fbbb3,bold] p #[fg=#859289,bg=#2e383c] pane #[fg=#272e33,bg=#83c092,bold] t #[fg=#859289,bg=#2e383c] tab #[fg=#272e33,bg=#dbbc7f,bold] r #[fg=#859289,bg=#2e383c] resize #[fg=#272e33,bg=#9da9a0,bold] m #[fg=#859289,bg=#2e383c] move #[fg=#272e33,bg=#d699b6,bold] s #[fg=#859289,bg=#2e383c] scroll #[fg=#272e33,bg=#e69875,bold] o #[fg=#859289,bg=#2e383c] session "
            mode_pane    "#[fg=#272e33,bg=#7fbbb3,bold] P #[fg=#272e33,bg=#7fbbb3,bold] h/j/k/l #[fg=#859289,bg=#2e383c] focus #[fg=#272e33,bg=#7fbbb3,bold] n #[fg=#859289,bg=#2e383c] pane #[fg=#272e33,bg=#7fbbb3,bold] r #[fg=#859289,bg=#2e383c] right #[fg=#272e33,bg=#7fbbb3,bold] d #[fg=#859289,bg=#2e383c] down #[fg=#272e33,bg=#7fbbb3,bold] s #[fg=#859289,bg=#2e383c] stack #[fg=#272e33,bg=#7fbbb3,bold] w #[fg=#859289,bg=#2e383c] float #[fg=#272e33,bg=#7fbbb3,bold] f #[fg=#859289,bg=#2e383c] full #[fg=#272e33,bg=#7fbbb3,bold] x #[fg=#859289,bg=#2e383c] close "
            mode_tab     "#[fg=#272e33,bg=#83c092,bold] T #[fg=#272e33,bg=#83c092,bold] h/l #[fg=#859289,bg=#2e383c] prev/next #[fg=#272e33,bg=#83c092,bold] n #[fg=#859289,bg=#2e383c] new #[fg=#272e33,bg=#83c092,bold] 1-9 #[fg=#859289,bg=#2e383c] jump #[fg=#272e33,bg=#83c092,bold] r #[fg=#859289,bg=#2e383c] rename #[fg=#272e33,bg=#83c092,bold] x #[fg=#859289,bg=#2e383c] close #[fg=#272e33,bg=#83c092,bold] s #[fg=#859289,bg=#2e383c] sync "
            mode_resize  "#[fg=#272e33,bg=#dbbc7f,bold] R #[fg=#272e33,bg=#dbbc7f,bold] h/j/k/l #[fg=#859289,bg=#2e383c] grow #[fg=#272e33,bg=#dbbc7f,bold] H/J/K/L #[fg=#859289,bg=#2e383c] shrink #[fg=#272e33,bg=#dbbc7f,bold] +/- #[fg=#859289,bg=#2e383c] size "
            mode_scroll  "#[fg=#272e33,bg=#d699b6,bold] S #[fg=#272e33,bg=#d699b6,bold] j/k #[fg=#859289,bg=#2e383c] scroll #[fg=#272e33,bg=#d699b6,bold] d/u #[fg=#859289,bg=#2e383c] half #[fg=#272e33,bg=#d699b6,bold] s #[fg=#859289,bg=#2e383c] search #[fg=#272e33,bg=#d699b6,bold] e #[fg=#859289,bg=#2e383c] edit #[fg=#272e33,bg=#d699b6,bold] C-c #[fg=#859289,bg=#2e383c] bottom "
            mode_session "#[fg=#272e33,bg=#e69875,bold] O #[fg=#272e33,bg=#e69875,bold] d #[fg=#859289,bg=#2e383c] detach #[fg=#272e33,bg=#e69875,bold] w #[fg=#859289,bg=#2e383c] manager #[fg=#272e33,bg=#e69875,bold] l #[fg=#859289,bg=#2e383c] layout #[fg=#272e33,bg=#e69875,bold] p #[fg=#859289,bg=#2e383c] plugin #[fg=#272e33,bg=#e69875,bold] c #[fg=#859289,bg=#2e383c] config #[fg=#272e33,bg=#e69875,bold] a #[fg=#859289,bg=#2e383c] about "
            mode_move    "#[fg=#272e33,bg=#9da9a0,bold] M #[fg=#272e33,bg=#9da9a0,bold] h/j/k/l #[fg=#859289,bg=#2e383c] move #[fg=#272e33,bg=#9da9a0,bold] n #[fg=#859289,bg=#2e383c] next #[fg=#272e33,bg=#9da9a0,bold] p #[fg=#859289,bg=#2e383c] prev "

            tab_normal "#[fg=#272e33,bg=#374145,bold] {index} #[fg=#9da9a0,bg=#2e383c] {name} "
            tab_active "#[fg=#272e33,bg=#83c092,bold] {index} #[fg=#272e33,bg=#a7c080,bold] {name} "
            tab_active_fullscreen "#[fg=#272e33,bg=#7fbbb3,bold] {index} #[fg=#272e33,bg=#83c092,bold] {name}{fullscreen_indicator} "
            tab_active_sync "#[fg=#272e33,bg=#d699b6,bold] {index} #[fg=#272e33,bg=#a7c080,bold] {name}{sync_indicator} "
            tab_normal_fullscreen "#[fg=#272e33,bg=#374145,bold] {index} #[fg=#9da9a0,bg=#2e383c] {name}{fullscreen_indicator} "
            tab_normal_sync "#[fg=#272e33,bg=#374145,bold] {index} #[fg=#9da9a0,bg=#2e383c] {name}{sync_indicator} "
            tab_separator ""
            tab_rename "#[fg=#272e33,bg=#dbbc7f,bold] rename #[fg=#859289,bg=#2e383c] {name} "
            tab_truncate_start_format "..."
            tab_truncate_end_format "..."
            tab_sync_indicator " S"
            tab_fullscreen_indicator " F"
            tab_floating_indicator " W"
        }
    }
}
